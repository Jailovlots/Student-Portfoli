{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:web": "pnpm --filter @workspace/mockup-sandbox run dev",
    "dev:expo": "pnpm --filter @workspace/student-enrollment run dev",
    "build:web": "pnpm --filter @workspace/mockup-sandbox run build",
    "preview:web": "pnpm --filter @workspace/mockup-sandbox run preview",
    "start": "pnpm --filter @workspace/student-enrollment run dev",
    "android": "pnpm --filter @workspace/student-enrollment exec expo start --android",
    "ios": "pnpm --filter @workspace/student-enrollment exec expo start --ios",
    "web": "pnpm --filter @workspace/student-enrollment exec expo start --web"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "expo": "~54.0.33"
  }
}
